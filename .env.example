# Copy this file to .env.local and fill in your secrets.

# Existing photo gallery integration (optional)
VITE_ANTHROPIC_API_KEY=sk-ant-...

# Smart Trails Nepal chatbot server
AZURE_OPENAI_ENDPOINT=https://nexalaris-tech.openai.azure.com/
AZURE_OPENAI_API_KEY=replace-with-your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-5.4
AZURE_OPENAI_API_VERSION=preview
API_PORT=8787
ALLOWED_ORIGIN=http://localhost:8080

# Optional frontend override if your API runs on a different origin
# VITE_CHAT_API_URL=https://your-api-host.example.com/api/chat
